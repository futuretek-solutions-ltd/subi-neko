# Directory where source MKV files are placed for import
IMPORT_ROOT=./media/import

# Directory where finished output files are written
OUTPUT_ROOT=./media/output

# Directory for the SQLite database and persistent config
CONFIG_ROOT=./config

# Numeric user/group and permissions used inside the container for writable files
PUID=1000
PGID=1000
UMASK=002

# Set to true to enable FastAPI debug mode (full tracebacks in HTTP error responses)
# and SQLAlchemy query logging. Never enable in production.
# DEBUG=false
